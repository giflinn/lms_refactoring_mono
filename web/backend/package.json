{
  "name": "lms-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx --env-file=.env scripts/seed-admin.ts",
    "seed:catalog": "tsx --env-file=.env scripts/seed-catalog.ts",
    "seed:managers": "tsx --env-file=.env scripts/seed-managers.ts",
    "import:clients": "tsx --env-file=.env scripts/import-clients.ts",
    "delete:imported-clients": "tsx --env-file=.env scripts/delete-imported-clients.ts",
    "seed:reviewer": "tsx --env-file=.env scripts/seed-reviewer.ts",
    "test": "tsx --test src/services/bcc/*.test.ts"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "grammy": "^1.42.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
