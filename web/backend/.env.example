PORT=3000
DATABASE_URL=postgresql://lms:lms@localhost:5432/lms
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SMTP for transactional emails (password reset OTP).
# Without these, /auth/password-reset/request will fail at runtime.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Slyamova Zhanna <noreply@slyamova.kz>"
# Optional: override TLS SNI / certificate hostname. Needed on shared hosting
# where the mail server presents a wildcard cert for the hosting provider's
# domain (e.g. *.hoster.kz) instead of your mail domain.
SMTP_TLS_SERVERNAME=

# Public HTTPS base URL the backend is reachable at. Used to register the
# Telegram bot webhook at ${BACKEND_PUBLIC_URL}/telegram/webhook. Required
# for the bot to receive updates; leave empty locally if you're not testing
# the bot (admin can still save the token, the webhook just won't be set).
# Production: https://app.zhannaslyamova.net/api
BACKEND_PUBLIC_URL=

# BCC (Bank CenterCredit) card-payment gateway. All optional — card payments
# just fail with payment_unavailable until set. Real values are deployed
# out-of-band (secrets, not committed). NOTIFY_URL / BACKREF are derived from
# BACKEND_PUBLIC_URL. See docs/bcc-payment-integration.md.
#   Test sandbox (public, from the doc): WEBVIEW_URL below, MERCHANT_ID=00000001,
#   TERMINAL_ID=88888881, MAC_KEY=6BB0AC02E47BDF73D98FEB777F3B5294.
#   Prod values (real MERCHANT_ID, TERMINAL_ID, MAC_KEY) come from BCC after
#   test-case sign-off; prod WEBVIEW_URL=https://3dsecure.bcc.kz/webview.
BCC_WEBVIEW_URL=https://test3ds.bcc.kz:5445/cgi-bin/cgi_link
BCC_MERCHANT_ID=
BCC_TERMINAL_ID=
# Assembled HMAC key — XOR of the two key components the bank issues.
BCC_MAC_KEY=
BCC_MERCH_NAME=IP Zhanna Slyamova
BCC_MERCH_RN_ID=
# Basic-Auth credentials we register with BCC for the NOTIFY_URL callback.
BCC_NOTIFY_USER=
BCC_NOTIFY_PASS=

# Apple In-App Purchase (StoreKit) — verifies iOS digital purchases and receives
# App Store Server Notifications V2. All optional; the Apple payment route fails
# with a clear error at first use if missing, so a dev machine still boots.
#   - APPLE_IAP_ISSUER_ID / KEY_ID: from App Store Connect → Users and Access →
#     Integrations → App Store Server API key.
#   - APPLE_IAP_PRIVATE_KEY: full contents of the downloaded .p8 (keep the
#     -----BEGIN PRIVATE KEY----- header; newlines as \n if your loader needs it).
#   - APPLE_IAP_BUNDLE_ID: kz.zhannaslyamova.lms.ios
# See docs/ios-appstore-compliance-tz.md.
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_BUNDLE_ID=kz.zhannaslyamova.lms.ios
# The app's numeric App Store ID (App Store Connect → App Information → General →
# Apple ID). Required to verify PRODUCTION purchases/notifications; Sandbox
# (App Review) does not need it. Also: drop the Apple Root CA certificates
# (*.cer from https://www.apple.com/certificateauthority/) into web/backend/apple-certs/.
APPLE_IAP_APP_APPLE_ID=

# Master key for app-level encryption of secrets stored in Postgres — currently
# the BCC MAC key + callback password the admin can enter in Settings → BCC →
# Реквизиты (so the business sets prod credentials without editing this file;
# DB values override the BCC_* fallback above). 32 bytes as 64 hex chars:
# generate with `openssl rand -hex 32`. Required only when using the
# admin-entered encrypted credentials. Deployed out-of-band (secret).
APP_ENCRYPTION_KEY=
